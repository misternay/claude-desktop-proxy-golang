# Required
OPENAI_API_KEY=sk-your-key-here

# Optional - Client API key validation
ANTHROPIC_API_KEY=

# Optional - OpenAI configuration
OPENAI_BASE_URL=https://api.openai.com/v1
AZURE_API_VERSION=

# Optional - Server configuration
HOST=0.0.0.0
PORT=8082
LOG_LEVEL=INFO

# Optional - Token limits
MAX_TOKENS_LIMIT=4096
MIN_TOKENS_LIMIT=100

# Optional - Connection settings
REQUEST_TIMEOUT=90
MAX_RETRIES=2

# Optional - Model mapping
BIG_MODEL=deepseek-v4-pro
MIDDLE_MODEL=qwen3.7-max
SMALL_MODEL=glm5.1

# Optional - Per-model configuration
BIG_MODEL_API_KEY=
BIG_MODEL_BASE_URL=
MIDDLE_MODEL_API_KEY=
MIDDLE_MODEL_BASE_URL=
SMALL_MODEL_API_KEY=
SMALL_MODEL_BASE_URL=

# Optional - Custom headers (format: CUSTOM_HEADER_XXX=value)
# CUSTOM_HEADER_X_CUSTOM=value
